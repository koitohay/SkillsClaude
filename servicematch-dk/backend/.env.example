# Copy to .env.Development (gitignored). Used by docker-compose and local dev.

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=servicematch;Username=postgres;Password=postgres

Jwt__Secret=local-dev-secret-at-least-32-chars!!
Jwt__Issuer=ServiceMatch
Jwt__Audience=ServiceMatchAPI
Jwt__ExpiryDays=7

Email__Provider=logging

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
